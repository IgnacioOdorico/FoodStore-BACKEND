# ─── Base de datos ────────────────────────────────────────────
# Match con docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=parcial2
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────
# Mínimo 32 caracteres. Generar con: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-minimum-32-chars-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ─── Debug / Entorno ──────────────────────────────────────────
# True → desarrollo (cookies sin secure, etc.). False → producción.
DEBUG=True
LOG_LEVEL=INFO

# ─── CORS ─────────────────────────────────────────────────────
# Lista de orígenes permitidos separada por comas
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:3000

# ─── Rate Limiting ────────────────────────────────────────────
# Límite general (por minuto / burst máximo)
RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_DEFAULT_BURST=100
# Límite estricto para auth (login, register)
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_AUTH_BURST=20

# ─── MercadoPago ──────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel
MP_ACCESS_TOKEN=TEST-your-access-token-here
MP_PUBLIC_KEY=TEST-your-public-key-here
# URL del webhook IPN — requiere URL pública (ngrok en desarrollo)
MP_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/api/v1/pagos/webhook
MP_WEBHOOK_SECRET=your-webhook-secret-here

# ─── NGROK ────────────────────────────────────────────────────
# URL pública generada por ngrok (para webhooks de MP en desarrollo)
# Obtener en: https://dashboard.ngrok.com
NGROK_URL=https://your-ngrok-url.ngrok-free.app
NGROK_AUTHTOKEN=your-ngrok-authtoken-here

# ─── Cloudinary ───────────────────────────────────────────────
# Obtener en: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── URLs del sistema ─────────────────────────────────────────
# URL base del backend (para construcción de back_urls de MP)
VITE_API_URL=http://localhost:8000
# URL del frontend Store (para redirección post-pago de MP)
VITE_FRONTEND_URL=http://localhost:5173
